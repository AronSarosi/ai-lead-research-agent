# Keep the build context small and never ship secrets or local cruft.

# Secrets - keys come from Cloud Run env / Secret Manager, never the image
.env
.env.*
!.env.example

# Virtual envs
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Version control
.git/
.gitignore

# Exports / local data
*.csv

# OS / editor
.DS_Store
.vscode/
.idea/

# Docs not needed at runtime
README.md
