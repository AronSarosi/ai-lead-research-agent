# Copy this file to .env and fill in your keys:  cp .env.example .env
# .env is gitignored - never commit your real keys.

# --- Provider ---------------------------------------------------------------
# 'openai' (default) or 'azure'
LLM_PROVIDER=openai

# Optional: lower = more consistent, higher = more varied (0.0-1.0).
# LLM_TEMPERATURE drives the research steps; LLM_DRAFT_TEMPERATURE the draft step.
LLM_TEMPERATURE=0.4
LLM_DRAFT_TEMPERATURE=0.6

# --- OpenAI (default) -------------------------------------------------------
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Cheap, fast model for the research steps:
OPENAI_MODEL=gpt-4o-mini
# Stronger model just for writing the outreach draft (swap to gpt-4.1 if you have it):
OPENAI_DRAFT_MODEL=gpt-4o

# --- Tavily (web search) ----------------------------------------------------
# Get a key (free tier available): https://app.tavily.com
TAVILY_API_KEY=

# --- Azure OpenAI (only if LLM_PROVIDER=azure) ------------------------------
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-mini-deployment
# AZURE_OPENAI_DRAFT_DEPLOYMENT=your-stronger-deployment
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Langfuse tracing (optional) --------------------------------------------
# Tracing only turns on when BOTH keys below are set. Get them at:
# https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
